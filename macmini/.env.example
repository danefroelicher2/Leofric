# Leofric brain configuration template (Mac Mini).
# Copy to ~/leofric-brain/.env and fill in. NEVER commit a real .env.

# --- LLM ---
# OLLAMA_URL=http://localhost:11434/api/chat
# LEOFRIC_MODEL=llama3.2

# --- Supabase (same project as the nodes) ---
SUPABASE_URL=
SUPABASE_KEY=

# --- APNs push notifications (Phase 2E; see docs/PHASE_2E_SETUP.md) ---
# All four must be set or push silently no-ops (by design — the brain runs
# fine without them).
# APNS_KEY_PATH=/Users/<you>/leofric-brain/AuthKey_XXXXXXXXXX.p8
# APNS_KEY_ID=XXXXXXXXXX
# APNS_TEAM_ID=XXXXXXXXXX
# APNS_BUNDLE_ID=com.danefroelicher.Leofric
# 1 for Xcode-signed dev builds (sandbox APNs), 0 for TestFlight/App Store.
# APNS_USE_SANDBOX=1

# --- Storage (defaults are fine) ---
# LEOFRIC_SNAPSHOT_DIR=~/leofric-brain/snapshots
# LEOFRIC_SNAPSHOT_KEEP=2000
