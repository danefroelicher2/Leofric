# Leofric node configuration template (one per Pi).
# Copy to .env on the node and fill in. .env is gitignored — NEVER commit it.
# Every value here overrides a default in config.py; config.py is the full
# catalog of tunables (camera, motion, identity, audio, streaming).

# --- Node identity (UNIQUE per node: front-door, driveway, garage, ...) ---
NODE_ID=leofric
# "security" nodes trigger snapshots + push notifications on person/identity
# events; other roles just stream and log.
NODE_ROLE=security

# --- Hardware (override if devices enumerate differently on this node) ---
CAMERA_DEVICE=/dev/video0
MIC_CARD=2

# --- Mac Mini brain (mDNS hostname survives DHCP; IP does not) ---
MAC_MINI_URL=http://Danes-Mac-mini-3.local:5000

# --- Supabase (durable event log) — from Project Settings -> API ---
# SUPABASE_KEY is the service_role (secret) key: the node is a trusted backend
# writing through RLS. Keep it secret.
SUPABASE_URL=
SUPABASE_KEY=

# --- Event logging ---
# Set to 0 to run vision + live feed WITHOUT logging events/snapshots.
# Was deliberately 0 at shelving time: continuous presence logged an event
# every few seconds. Build smart/debounced alerting (ROADMAP Phase 3, first
# task) before turning this back on.
EVENT_LOGGING_ENABLED=0

# --- Live feed (defaults in config.py; common per-node overrides) ---
# STREAM_FPS=15
# STREAM_JPEG_QUALITY=70
# MOTION_MIN_AREA=5000        # re-tune per scene when a node moves
