# Leofric configuration template.
# Copy this file to .env on the Pi and fill in real values as each phase needs them.
# .env is gitignored and must NEVER be committed.

# --- Node identity ---
NODE_ID=leofric

# --- Hardware (already known from Phase 1A; override only if devices move) ---
CAMERA_DEVICE=/dev/video0
MIC_CARD=2

# --- Mac Mini brain (do not change unless the Mac Mini IP changes) ---
MAC_MINI_URL=http://192.168.1.46:5000

# --- Picovoice wake word (Phase 1H) — from https://console.picovoice.ai ---
PICOVOICE_ACCESS_KEY=

# --- Supabase (Phase 1G) — from your Supabase project settings ---
SUPABASE_URL=
SUPABASE_KEY=
