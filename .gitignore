# Python
__pycache__/
*.py[cod]
*.egg-info/
.Python

# Virtual environment (created on the Pi, never committed)
venv/
.venv/

# Secrets — real values live only in .env on the Pi
.env

# Runtime artifacts (keep the folders, ignore their contents)
data/*
!data/.gitkeep
logs/*
!logs/.gitkeep
# Event snapshots are written on the Mac only, never committed (privacy).
macmini/snapshots/
# Device tokens are written on the Mac only, never committed.
macmini/devices.json

# Hardware check outputs
hwcheck_frame.jpg
hwcheck_audio.wav

# OS
.DS_Store
Thumbs.db

# iOS build artifacts (the .xcodeproj itself IS committed — XcodeGen-generated
# but treated as source of truth for opening in Xcode; only derived/user state
# is ignored)
ios/LeofricApp/.build/
ios/LeofricApp/*.xcodeproj/xcuserdata/
ios/LeofricApp/*.xcodeproj/project.xcworkspace/xcuserdata/
